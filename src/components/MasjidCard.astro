---
import { Image } from 'astro:assets';
import type { Masjid } from '../data/masajids';

interface Props {
  masjid: Masjid;
}

const { masjid } = Astro.props;
---

<a href={`/masajids/${masjid.slug}/`} class="card masjid-card">
  <Image
    src={masjid.image}
    alt={`Congregation at ${masjid.name}`}
    width={400}
    height={260}
    class="masjid-card__photo"
  />
  <div class="masjid-card__body">
    <span class="tag">{masjid.city}</span>
    <h3>{masjid.name}</h3>
    <p>{masjid.description}</p>
    <span class="masjid-card__link">View details &rarr;</span>
  </div>
</a>

<style>
  .masjid-card {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    padding: 0;
    overflow: hidden;
  }

  .masjid-card__photo {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .masjid-card__body {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .masjid-card p {
    color: var(--color-ink-700);
    flex-grow: 1;
  }

  .masjid-card__link {
    font-weight: 600;
    color: var(--color-green-700);
    font-size: 0.9rem;
  }
</style>
