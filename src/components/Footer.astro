---
import { footerNav, siteInfo, socialLinks } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-about">
      <span class="brand__name">MAS Minnesota</span>
      <p class="lede">{siteInfo.fullName} — {siteInfo.tagline}</p>
      <ul class="social-list">
        {
          socialLinks.map((link) => (
            <li>
              <a href={link.href} target="_blank" rel="noopener noreferrer">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="footer-col">
      <h3>Contact</h3>
      <p>
        {siteInfo.address}<br />
        <a href={siteInfo.phoneHref}>{siteInfo.phone}</a><br />
        <a href={`mailto:${siteInfo.email}`}>{siteInfo.email}</a>
      </p>
    </div>

    <div class="footer-col">
      <h3>Explore</h3>
      <ul class="footer-links">
        <li><a href="/masajids/">Our Masajid</a></li>
        <li><a href="/programs/">Programs &amp; Services</a></li>
        <li><a href="/about/">About MAS MN</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h3>Resources</h3>
      <ul class="footer-links">
        {
          footerNav.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>&copy; {year} Muslim American Society of Minnesota. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-green-900);
    color: var(--color-green-100);
    padding-block: 3.5rem 1.5rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 2.5rem;
  }

  .footer-about .brand__name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-white);
  }

  .footer-about .lede {
    color: var(--color-green-100);
    margin-top: 0.5rem;
  }

  .social-list {
    display: flex;
    gap: 1rem;
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    flex-wrap: wrap;
  }

  .social-list a {
    text-decoration: none;
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--color-gold-500);
  }

  .footer-col h3 {
    color: var(--color-white);
    font-size: 1rem;
    margin-bottom: 0.85rem;
  }

  .footer-col p {
    color: var(--color-green-100);
    font-size: 0.9rem;
  }

  .footer-col a {
    color: var(--color-green-100);
    text-decoration: none;
  }

  .footer-col a:hover {
    color: var(--color-gold-500);
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    font-size: 0.9rem;
  }

  .footer-bottom {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    font-size: 0.8rem;
    color: var(--color-green-100);
  }

  @media (max-width: 800px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 520px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
