---
import { mainNav, siteInfo } from '../data/site';

const currentPath = Astro.url.pathname;
const isActive = (href: string) => href !== '/' && currentPath.startsWith(href);
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="brand">
      <span class="brand__mark" aria-hidden="true">
        <svg viewBox="0 0 48 48" width="36" height="36" role="presentation">
          <path
            d="M24 4c-3 5-9 8-9 16 0 7 4 12 9 14 5-2 9-7 9-14 0-8-6-11-9-16Z"
            fill="var(--color-gold-500)"
          ></path>
          <circle cx="24" cy="24" r="21" fill="none" stroke="var(--color-green-800)" stroke-width="2"></circle>
        </svg>
      </span>
      <span class="brand__text">
        <span class="brand__name">MAS Minnesota</span>
        <span class="brand__sub">masmn.org</span>
      </span>
    </a>

    <nav class="main-nav" aria-label="Primary">
      <ul>
        {
          mainNav.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={['main-nav__link', { 'is-active': isActive(item.href) }]}
                target={item.external ? '_blank' : undefined}
                rel={item.external ? 'noopener noreferrer' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="header-actions">
      <a href={siteInfo.phoneHref} class="header-phone">
        {siteInfo.phone}
      </a>
      <a href={siteInfo.donateUrl} class="btn btn-primary">Donate</a>
      <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="mobile-nav">
        <span class="visually-hidden">Toggle menu</span>
        <span class="nav-toggle__bar"></span>
        <span class="nav-toggle__bar"></span>
        <span class="nav-toggle__bar"></span>
      </button>
    </div>
  </div>

  <nav id="mobile-nav" class="mobile-nav" aria-label="Mobile">
    <ul>
      {
        mainNav.map((item) => (
          <li>
            <a href={item.href} target={item.external ? '_blank' : undefined} rel={item.external ? 'noopener noreferrer' : undefined}>
              {item.label}
            </a>
          </li>
        ))
      }
      <li><a href={siteInfo.donateUrl} class="btn btn-primary">Donate</a></li>
    </ul>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(251, 248, 242, 0.92);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(13, 59, 46, 0.08);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding-block: 0.85rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
  }

  .brand__text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .brand__name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--color-green-900);
  }

  .brand__sub {
    font-size: 0.7rem;
    color: var(--color-ink-500);
    letter-spacing: 0.04em;
  }

  .main-nav ul {
    display: flex;
    gap: 1.75rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .main-nav__link {
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-ink-700);
    padding-block: 0.25rem;
    border-bottom: 2px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .main-nav__link:hover,
  .main-nav__link.is-active {
    color: var(--color-green-800);
    border-color: var(--color-gold-500);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .header-phone {
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    color: var(--color-green-800);
    white-space: nowrap;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 36px;
    height: 36px;
    background: transparent;
    border: 1px solid rgba(13, 59, 46, 0.2);
    border-radius: 0.5rem;
    cursor: pointer;
  }

  .nav-toggle__bar {
    display: block;
    width: 18px;
    height: 2px;
    margin-inline: auto;
    background: var(--color-green-900);
  }

  .mobile-nav {
    display: none;
  }

  @media (max-width: 860px) {
    .main-nav,
    .header-phone {
      display: none;
    }

    .nav-toggle {
      display: flex;
    }

    .mobile-nav {
      display: none;
      border-top: 1px solid rgba(13, 59, 46, 0.08);
      background: var(--color-sand-50);
    }

    .mobile-nav.is-open {
      display: block;
    }

    .mobile-nav ul {
      list-style: none;
      margin: 0;
      padding: 1rem 1.5rem 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.9rem;
    }

    .mobile-nav a {
      text-decoration: none;
      font-weight: 600;
      color: var(--color-green-900);
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const mobileNav = document.getElementById('mobile-nav');

  toggle?.addEventListener('click', () => {
    const isOpen = mobileNav?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(Boolean(isOpen)));
  });
</script>
