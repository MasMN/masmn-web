---
interface Props {
  eyebrow?: string;
  title: string;
  lede?: string;
}

const { eyebrow, title, lede } = Astro.props;
---

<section class="page-hero section--green section--tight">
  <div class="container">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    {lede && <p class="lede">{lede}</p>}
  </div>
</section>
