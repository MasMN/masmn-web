---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found">
  <section class="section section--green not-found">
    <div class="container">
      <p class="eyebrow">404</p>
      <h1>We couldn't find that page</h1>
      <p class="lede">The page you're looking for may have moved. Try one of the links below.</p>
      <div class="not-found__actions">
        <a href="/" class="btn btn-primary">Back to Home</a>
        <a href="/masajids/" class="btn btn-outline">Find a Masjid</a>
        <a href="/contact/" class="btn btn-outline">Contact Us</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: 60vh;
    display: flex;
    align-items: center;
  }

  .not-found__actions {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
    flex-wrap: wrap;
  }
</style>
